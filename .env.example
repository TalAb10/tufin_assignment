# ── Required ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...                  # Your OpenAI API key

# ── Optional (defaults shown) ─────────────────────────────────
OPENAI_MODEL=gpt-5.4                   # OpenAI model to use
MAX_AGENT_ITERATIONS=10                # Max ReAct loop iterations

DATABASE_URL=postgresql+asyncpg://agent:secret@localhost:5432/agentdb
LOG_LEVEL=INFO
DEBUG=false
